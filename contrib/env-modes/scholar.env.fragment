# Mode: scholar — retrieval-first; merge into gzmo-daemon/.env (set models locally)
GZMO_PROFILE=interactive

# Higher recall for search tasks (VRAM / context permitting)
GZMO_TOPK=10
GZMO_EVIDENCE_MAX_SNIPPETS=12

# Optionally ground think prompts that reference the vault/wiki
GZMO_THINK_RETRIEVAL=on
GZMO_THINK_TOPK=5
