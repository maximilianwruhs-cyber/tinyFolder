# Mode: writer — merge into gzmo-daemon/.env (do not overwrite secrets / VAULT_PATH)
GZMO_PROFILE=core

# Ground think tasks sometimes (only when prompts look vault-scoped — see README)
GZMO_THINK_RETRIEVAL=light
GZMO_THINK_TOPK=4

# Broader episodic memory strip in system prompts
GZMO_MEMORY_MAX_ENTRIES=12
GZMO_MEMORY_SUMMARY_CHARS=160

# Optional: surface recent Thought_Cabinet notes as short bullets
GZMO_MEMORY_WORKING_SET=cabinet
GZMO_MEMORY_WORKING_SET_MAX_FILES=5
