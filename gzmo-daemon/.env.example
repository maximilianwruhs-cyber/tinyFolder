# Laptop / generic GZMO daemon — copy to `gzmo-daemon/.env` and edit (never commit `.env`).
# VAULT_PATH must be absolute.
#
# Model tiers (full table): README.md → Prerequisites → Recommended models
# - Code default when OLLAMA_MODEL is unset: hermes3:8b (safe for 4–8 GB class).
# - Quality reference (best overall): qwen3.6:35b-a3b-nvfp4 on Blackwell (RTX 50xx, DGX Spark GB10).
# - Workstation ≈24 GB+ without NVFP4: set OLLAMA_MODEL=qwen3.6:35b-a3b (~24 GB Q4 in Ollama).
# - Blackwell / Spark: use gzmo-daemon/.env.spark.example instead.

VAULT_PATH="/absolute/path/to/your/GZMO-Vault"

# Optional: desktop Dropzone outside the vault (absolute path).
# GZMO_DROPZONE_DIR="/absolute/path/to/GZMO-Dropzone"

OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="hermes3:8b"

# Workstation (≈24 GB VRAM, non-Blackwell) — uncomment and pull: ollama pull qwen3.6:35b-a3b
# OLLAMA_MODEL="qwen3.6:35b-a3b"

GZMO_EMBED_MODEL="nomic-embed-text"

# Unset in env → defaults to `core` in code. Use `art` for chaos/dreams with wiki + auto-inbox bridges quieter.
# GZMO_PROFILE=core
