# DGX Spark / document RAG — copy to `gzmo-daemon/.env` and edit (never commit `.env`).
# VAULT_PATH must be absolute.

VAULT_PATH="/absolute/path/to/your/GZMO-Vault"
GZMO_DROPZONE_DIR="/absolute/path/to/GZMO-Dropzone"

OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="qwen3.6:35b-a3b-nvfp4"
GZMO_EMBED_MODEL="nomic-embed-text"

GZMO_PROFILE="core"

# Invoice / bill RAG (raise if answers feel under-grounded)
GZMO_TOPK="12"
GZMO_EVIDENCE_MAX_SNIPPETS="16"
GZMO_EVIDENCE_MAX_CHARS="2400"
GZMO_LLM_MAX_TOKENS="2048"

# Optional after: ollama pull qwen3-embedding:4b
# GZMO_EMBED_MODEL="qwen3-embedding:4b"
